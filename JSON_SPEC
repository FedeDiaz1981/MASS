{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 1200,
  "height": 675,
  "padding": 0,

  "data": [
    {
      "name": "dataset"
    },
    {
      "name": "machine",
      "source": "dataset",
      "transform": [
        {
          "type": "aggregate",
          "fields": ["SelectedImageURL"],
          "ops": ["max"],
          "as": ["ImageURL"]
        }
      ]
    }
  ],

  "signals": [
    {
      "name": "selected",
      "value": null,
      "on": [
        { "events": "@zone:click", "update": "datum.Key" },
        { "events": "dblclick", "update": "null" }
      ]
    },
    {
      "name": "hoverKey",
      "value": null,
      "on": [
        { "events": "@zone:mouseover", "update": "datum.Key" },
        { "events": "@zone:mouseout", "update": "null" }
      ]
    }
  ],

  "marks": [

    /* Imagen de fondo */
    {
      "type": "image",
      "from": { "data": "machine" },
      "encode": {
        "enter": {
          "x": { "value": 0 },
          "y": { "value": 0 },
          "width": { "value": 1200 },
          "height": { "value": 675 }
        },
        "update": {
          "url": { "field": "ImageURL" }
        }
      }
    },

    /* Glow */
    {
      "type": "polygon",
      "name": "zoneGlow",
      "from": { "data": "dataset" },
      "encode": {
        "enter": {
          "points": { "signal": "fromJSON(datum.Points)" },
          "fill": { "value": null },
          "stroke": { "value": "#1f77b4" },
          "strokeWidth": { "value": 18 }
        },
        "update": {
          "strokeOpacity": [
            { "test": "datum.Key === selected", "value": 0.35 },
            { "test": "datum.Key === hoverKey", "value": 0.25 },
            { "value": 0 }
          ]
        }
      }
    },

    /* Zona interactiva */
    {
      "type": "polygon",
      "name": "zone",
      "from": { "data": "dataset" },
      "encode": {
        "enter": {
          "points": { "signal": "fromJSON(datum.Points)" },
          "cursor": { "value": "pointer" },
          "stroke": { "value": "#666" },
          "strokeWidth": { "value": 2 }
        },
        "update": {
          "fill": [
            { "test": "datum.Key === selected", "value": "#1f77b4" },
            { "value": "#000000" }
          ],
          "fillOpacity": [
            { "test": "datum.Key === selected", "value": 0.25 },
            { "test": "datum.Key === hoverKey", "value": 0.18 },
            { "value": 0.05 }
          ]
        }
      }
    },

    /* Tooltip simple arriba a la izquierda */
    {
      "type": "text",
      "encode": {
        "enter": {
          "x": { "value": 20 },
          "y": { "value": 30 },
          "font": { "value": "Segoe UI" },
          "fontSize": { "value": 18 },
          "fill": { "value": "#111" }
        },
        "update": {
          "text": {
            "signal": "hoverKey === null ? 'Pasá el cursor sobre una parte' : 'Parte: ' + datum.Title"
          }
        }
      }
    }
  ]
}
