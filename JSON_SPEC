<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="675" viewBox="0 0 1200 675">
  <!-- Background image (poné el nombre real del archivo) -->
  <image href="machine.png" x="0" y="0" width="1200" height="675" preserveAspectRatio="xMidYMid slice" />

  <!-- === Botones (solo 3) === -->
  <!-- Botón A -->
  <g id="A" cursor="pointer">
    <rect x="60" y="40" width="260" height="90" rx="18" ry="18" fill="#e6e6e6" stroke="#666" stroke-width="3"/>
    <text x="190" y="95" text-anchor="middle" dominant-baseline="middle"
          font-family="Segoe UI, Arial, sans-serif" font-size="28" fill="#111">
      Motor (A)
    </text>
  </g>

  <!-- Botón B -->
  <g id="B" cursor="pointer">
    <rect x="340" y="40" width="260" height="90" rx="18" ry="18" fill="#e6e6e6" stroke="#666" stroke-width="3"/>
    <text x="470" y="95" text-anchor="middle" dominant-baseline="middle"
          font-family="Segoe UI, Arial, sans-serif" font-size="28" fill="#111">
      Banda (B)
    </text>
  </g>

  <!-- Botón C -->
  <g id="C" cursor="pointer">
    <rect x="620" y="40" width="260" height="90" rx="18" ry="18" fill="#e6e6e6" stroke="#666" stroke-width="3"/>
    <text x="750" y="95" text-anchor="middle" dominant-baseline="middle"
          font-family="Segoe UI, Arial, sans-serif" font-size="28" fill="#111">
      Sensor (C)
    </text>
  </g>

  <!-- Nota: la “clickeabilidad” real la maneja Deneb/Synoptic (mapeando por id o por campo Key) -->
</svg>
