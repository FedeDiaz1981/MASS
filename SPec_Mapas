{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "description": "Hotspots sobre imagen de fondo",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },

  "width": 900,
  "height": 550,

  "signals": [
    { "name": "defaultBtnWidth", "value": 120 },
    { "name": "defaultBtnHeight", "value": 30 }
  ],

  "data": [
    {
      "name": "dataset"
    },
    {
      "name": "botones",
      "source": "dataset",
      "transform": [
        {
          "type": "filter",
          "expr": "isValid(datum.Boton)"
        },
        {
          "type": "collect",
          "sort": {
            "field": "order",
            "order": "ascending"
          }
        }
      ]
    }
  ],

  "marks": [
    {
      "type": "rule",
      "from": { "data": "botones" },
      "encode": {
        "enter": {
          "x": { "signal": "datum.labelx * width + defaultBtnWidth / 2" },
          "y": { "signal": "datum.labely * height + defaultBtnHeight / 2" },
          "x2": { "signal": "datum.pointx * width" },
          "y2": { "signal": "datum.pointy * height" },
          "stroke": { "value": "#49B3FF" },
          "strokeWidth": { "value": 2 }
        }
      }
    },

    {
      "type": "symbol",
      "from": { "data": "botones" },
      "encode": {
        "enter": {
          "x": { "signal": "datum.pointx * width" },
          "y": { "signal": "datum.pointy * height" },
          "size": { "value": 80 },
          "fill": { "value": "#A6ECFF" },
          "stroke": { "value": "#49B3FF" },
          "strokeWidth": { "value": 2 }
        }
      }
    },

    {
      "type": "rect",
      "from": { "data": "botones" },
      "encode": {
        "enter": {
          "x": { "signal": "datum.labelx * width" },
          "y": { "signal": "datum.labely * height" },
          "width": { "signal": "defaultBtnWidth" },
          "height": { "signal": "defaultBtnHeight" },
          "fillOpacity": { "value": 0 },
          "stroke": { "value": "#72D1FF" },
          "strokeWidth": { "value": 2 }
        },
        "update": {
          "tooltip": {
            "signal": "{'Botón': datum.Boton, 'Detalle': datum.tooltip}"
          }
        }
      }
    },

    {
      "type": "text",
      "from": { "data": "botones" },
      "encode": {
        "enter": {
          "x": { "signal": "datum.labelx * width + defaultBtnWidth / 2" },
          "y": { "signal": "datum.labely * height + defaultBtnHeight / 2" },
          "text": { "field": "Boton" },
          "align": { "value": "center" },
          "baseline": { "value": "middle" },
          "fill": { "value": "#2F80ED" },
          "fontSize": { "value": 12 },
          "fontWeight": { "value": "bold" }
        }
      }
    }
  ]
}
