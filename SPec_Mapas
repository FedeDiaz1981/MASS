{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "description": "Mapa técnico con imagen dinámica y botones",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "padding": 0,
  "width": 900,
  "height": 550,

  "signals": [
    { "name": "defaultBtnWidth", "value": 120 },
    { "name": "defaultBtnHeight", "value": 30 },

    {
      "name": "imgWidth",
      "update": "data('mapa').length ? (data('mapa')[0].ancho / data('mapa')[0].alto > width / height ? width : height * data('mapa')[0].ancho / data('mapa')[0].alto) : width"
    },
    {
      "name": "imgHeight",
      "update": "data('mapa').length ? (data('mapa')[0].ancho / data('mapa')[0].alto > width / height ? width * data('mapa')[0].alto / data('mapa')[0].ancho : height) : height"
    },
    {
      "name": "imgX",
      "update": "(width - imgWidth) / 2"
    },
    {
      "name": "imgY",
      "update": "(height - imgHeight) / 2"
    }
  ],

  "data": [
    {
      "name": "dataset"
    },
    {
      "name": "mapa",
      "source": "dataset",
      "transform": [
        {
          "type": "filter",
          "expr": "isValid(datum.Url) && datum.Url != ''"
        },
        {
          "type": "aggregate",
          "groupby": ["Url", "ancho", "alto"]
        }
      ]
    },
    {
      "name": "botones",
      "source": "dataset",
      "transform": [
        {
          "type": "filter",
          "expr": "isValid(datum.Boton) && datum.Boton != '' && isValid(datum.labelx) && isValid(datum.labely) && isValid(datum.pointx) && isValid(datum.pointy)"
        },
        {
          "type": "collect",
          "sort": {
            "field": "order",
            "order": "ascending"
          }
        }
      ]
    }
  ],

  "marks": [
    {
      "type": "image",
      "from": { "data": "mapa" },
      "encode": {
        "enter": {
          "x": { "signal": "imgX" },
          "y": { "signal": "imgY" },
          "width": { "signal": "imgWidth" },
          "height": { "signal": "imgHeight" },
          "url": { "field": "Url" }
        }
      }
    },

    {
      "type": "rule",
      "from": { "data": "botones" },
      "encode": {
        "enter": {
          "x": { "signal": "imgX + datum.labelx * imgWidth + defaultBtnWidth / 2" },
          "y": { "signal": "imgY + datum.labely * imgHeight + defaultBtnHeight / 2" },
          "x2": { "signal": "imgX + datum.pointx * imgWidth" },
          "y2": { "signal": "imgY + datum.pointy * imgHeight" },
          "stroke": { "value": "#49B3FF" },
          "strokeWidth": { "value": 2 }
        }
      }
    },

    {
      "type": "symbol",
      "from": { "data": "botones" },
      "encode": {
        "enter": {
          "x": { "signal": "imgX + datum.pointx * imgWidth" },
          "y": { "signal": "imgY + datum.pointy * imgHeight" },
          "size": { "value": 80 },
          "fill": { "value": "#A6ECFF" },
          "stroke": { "value": "#49B3FF" },
          "strokeWidth": { "value": 2 }
        }
      }
    },

    {
      "type": "rect",
      "from": { "data": "botones" },
      "encode": {
        "enter": {
          "x": { "signal": "imgX + datum.labelx * imgWidth" },
          "y": { "signal": "imgY + datum.labely * imgHeight" },
          "width": { "signal": "defaultBtnWidth" },
          "height": { "signal": "defaultBtnHeight" },
          "fill": {
            "signal": "isValid(datum.color) && datum.color != '' ? datum.color : '#2F80ED'"
          },
          "cornerRadius": { "value": 14 },
          "stroke": { "value": "#72D1FF" },
          "strokeWidth": { "value": 1.5 },
          "cursor": { "value": "pointer" }
        },
        "update": {
          "tooltip": {
            "signal": "{'Botón': datum.Boton, 'Detalle': datum.tooltip, 'Mapa': datum.nombreMapa}"
          }
        },
        "hover": {
          "strokeWidth": { "value": 2.5 },
          "fillOpacity": { "value": 0.9 }
        }
      }
    },

    {
      "type": "text",
      "from": { "data": "botones" },
      "encode": {
        "enter": {
          "x": { "signal": "imgX + datum.labelx * imgWidth + defaultBtnWidth / 2" },
          "y": { "signal": "imgY + datum.labely * imgHeight + defaultBtnHeight / 2" },
          "text": { "field": "Boton" },
          "align": { "value": "center" },
          "baseline": { "value": "middle" },
          "fill": { "value": "white" },
          "fontSize": { "value": 12 },
          "fontWeight": { "value": "bold" },
          "limit": { "signal": "defaultBtnWidth - 16" },
          "ellipsis": { "value": "..." }
        }
      }
    }
  ]
}
